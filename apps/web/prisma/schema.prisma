generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js Adapter Tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  appUser       AppUser?

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Application Tables
model Community {
  id                   String    @id @default(uuid()) @db.Uuid
  name                 String
  slug                 String    @unique
  address              String?
  state                String    @db.VarChar(2)
  totalHomes           Int       @default(0) @map("total_homes")
  monthlyDues          Decimal?  @map("monthly_dues") @db.Decimal(10, 2)
  fiscalYearStart      Int       @default(1) @map("fiscal_year_start")
  timezone             String    @default("America/New_York")
  plan                 String    @default("free")
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  settings             Json      @default("{}")
  status               String    @default("active")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  users                AppUser[]
  homes                Home[]
  documents            Document[]
  documentChunks       DocumentChunk[]
  meetings             Meeting[]
  violations           Violation[]
  arcRequests          ArcRequest[]
  invoices             Invoice[]
  payments             Payment[]
  transactions         Transaction[]
  importBatches        ImportBatch[]
  bankAccounts         BankAccount[]
  announcements        Announcement[]
  complianceItems      ComplianceItem[]
  maintenanceRequests  MaintenanceRequest[]
  chatSessions         ChatSession[]
  activityLogs         ActivityLog[]

  @@map("communities")
}

model AppUser {
  id                 String   @id @default(uuid()) @db.Uuid
  authUserId         String   @unique @map("auth_user_id")
  communityId        String   @map("community_id") @db.Uuid
  role               String   @default("homeowner")
  firstName          String   @map("first_name")
  lastName           String   @map("last_name")
  phone              String?
  avatarUrl          String?  @map("avatar_url")
  homeId             String?  @map("home_id") @db.Uuid
  isActive           Boolean  @default(true) @map("is_active")
  notificationPrefs  Json     @default("{\"email\":true,\"push\":true,\"sms\":false}") @map("notification_prefs")
  lastLoginAt        DateTime? @map("last_login_at")

  authUser  User      @relation(fields: [authUserId], references: [id])
  community Community @relation(fields: [communityId], references: [id])
  home      Home?     @relation(fields: [homeId], references: [id])

  @@index([communityId, role])
  @@index([homeId])
  @@index([isActive])
  @@map("app_users")
}

model Home {
  id            String    @id @default(uuid()) @db.Uuid
  communityId   String    @map("community_id") @db.Uuid
  unitNumber    String?   @map("unit_number")
  address       String?
  ownerName     String?   @map("owner_name")
  ownerEmail    String?   @map("owner_email")
  ownerPhone    String?   @map("owner_phone")
  isRented      Boolean   @default(false) @map("is_rented")
  tenantName    String?   @map("tenant_name")
  tenantEmail   String?   @map("tenant_email")
  tenantPhone   String?   @map("tenant_phone")
  status        String    @default("occupied")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])
  residents AppUser[]
  violations Violation[]
  arcRequests ArcRequest[]
  invoices Invoice[]
  payments Payment[]
  maintenanceRequests MaintenanceRequest[]

  @@unique([communityId, unitNumber])
  @@index([status])
  @@map("homes")
}

model Document {
  id          String    @id @default(uuid()) @db.Uuid
  communityId String    @map("community_id") @db.Uuid
  title       String
  type        String
  filePath    String?   @map("file_path")
  fileName    String?   @map("file_name")
  fileSize    Int?      @map("file_size")
  mimeType    String?   @map("mime_type")
  contentText String?   @map("content_text")
  uploadedBy  String?   @map("uploaded_by") @db.Uuid
  version     Int       @default(1)
  isPublic    Boolean   @default(false) @map("is_public")
  expiresAt   DateTime? @map("expires_at")
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])
  chunks DocumentChunk[]

  @@index([communityId, type])
  @@index([isPublic])
  @@index([expiresAt])
  @@map("documents")
}

model DocumentChunk {
  id          String    @id @default(uuid()) @db.Uuid
  communityId String    @map("community_id") @db.Uuid
  documentId  String    @map("document_id") @db.Uuid
  chunkIndex  Int       @map("chunk_index")
  content     String
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Note: embedding stored via raw SQL with pgvector extension
  // Use Prisma.$queryRaw for vector operations

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id])

  @@index([documentId])
  @@map("document_chunks")
}

model Meeting {
  id                  String    @id @default(uuid()) @db.Uuid
  communityId         String    @map("community_id") @db.Uuid
  title               String
  type                String    @default("regular")
  scheduledAt         DateTime  @map("scheduled_at")
  location            String?
  agenda              Json      @default("[]")
  minutes             String?
  minutesPublishedAt  DateTime? @map("minutes_published_at")
  status              String    @default("scheduled")
  createdBy           String?   @map("created_by") @db.Uuid
  attendees           Json      @default("[]")
  votes               Json      @default("[]")
  actionItems         Json      @default("[]") @map("action_items")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])

  @@index([communityId, scheduledAt])
  @@index([status])
  @@map("meetings")
}

model Violation {
  id               String    @id @default(uuid()) @db.Uuid
  communityId      String    @map("community_id") @db.Uuid
  homeId           String    @map("home_id") @db.Uuid
  reportedBy       String?   @map("reported_by") @db.Uuid
  type             String
  description      String
  photos           Json      @default("[]")
  location         String?
  status           String    @default("open")
  priority         String    @default("normal")
  dueDate          DateTime? @map("due_date")
  resolvedAt       DateTime? @map("resolved_at")
  resolutionNotes  String?   @map("resolution_notes")
  fineAmount       Decimal?  @map("fine_amount") @db.Decimal(10, 2)
  reminderCount    Int       @default(0) @map("reminder_count")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])
  home      Home    @relation(fields: [homeId], references: [id])

  @@index([communityId, status])
  @@index([priority])
  @@index([dueDate])
  @@map("violations")
}

model ArcRequest {
  id            String    @id @default(uuid()) @db.Uuid
  communityId   String    @map("community_id") @db.Uuid
  homeId        String    @map("home_id") @db.Uuid
  requestedBy   String    @map("requested_by") @db.Uuid
  projectType   String?   @map("project_type")
  description   String
  documents     Json      @default("[]")
  status        String    @default("submitted")
  reviewDeadline DateTime? @map("review_deadline")
  approvedBy    String?   @map("approved_by") @db.Uuid
  approvedAt    DateTime? @map("approved_at")
  conditions    String?
  denialReason  String?   @map("denial_reason")
  votes         Json      @default("[]")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])
  home      Home    @relation(fields: [homeId], references: [id])

  @@index([communityId, status])
  @@index([reviewDeadline])
  @@map("arc_requests")
}

model Invoice {
  id                String    @id @default(uuid()) @db.Uuid
  communityId       String    @map("community_id") @db.Uuid
  homeId            String    @map("home_id") @db.Uuid
  invoiceNumber     String    @map("invoice_number")
  type              String    @default("dues")
  description       String?
  amount            Decimal   @db.Decimal(10, 2)
  balanceDue        Decimal   @map("balance_due") @db.Decimal(10, 2)
  issuedAt          DateTime  @map("issued_at")
  dueAt             DateTime  @map("due_at")
  paidAt            DateTime? @map("paid_at")
  status            String    @default("outstanding")
  lateFeeApplied    Boolean   @default(false) @map("late_fee_applied")
  lateFeeAmount     Decimal?  @map("late_fee_amount") @db.Decimal(10, 2)
  stripeInvoiceId   String?   @map("stripe_invoice_id")
  metadata          Json      @default("{}")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])
  home      Home    @relation(fields: [homeId], references: [id])
  payments  Payment[]

  @@unique([communityId, invoiceNumber])
  @@index([status])
  @@index([dueAt])
  @@map("invoices")
}

model Payment {
  id                    String    @id @default(uuid()) @db.Uuid
  communityId           String    @map("community_id") @db.Uuid
  invoiceId             String    @map("invoice_id") @db.Uuid
  homeId                String    @map("home_id") @db.Uuid
  paidBy                String?   @map("paid_by") @db.Uuid
  amount                Decimal   @db.Decimal(10, 2)
  method                String?
  stripePaymentIntentId String?   @map("stripe_payment_intent_id")
  status                String    @default("pending")
  paidAt                DateTime? @map("paid_at")
  receiptUrl            String?   @map("receipt_url")
  createdAt             DateTime  @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id])
  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  home      Home    @relation(fields: [homeId], references: [id])

  @@index([invoiceId])
  @@map("payments")
}

model Transaction {
  id              String    @id @default(uuid()) @db.Uuid
  communityId     String    @map("community_id") @db.Uuid
  bankAccountId   String    @map("bank_account_id") @db.Uuid
  importBatchId   String?   @map("import_batch_id") @db.Uuid
  date            DateTime
  description     String?
  merchantName    String?   @map("merchant_name")
  amount          Decimal   @db.Decimal(10, 2)
  category        String?
  reconciled      Boolean   @default(false)
  matchedInvoiceId String?  @map("matched_invoice_id") @db.Uuid
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id])

  @@index([communityId, date])
  @@index([reconciled])
  @@map("transactions")
}

model ImportBatch {
  id              String    @id @default(uuid()) @db.Uuid
  communityId     String    @map("community_id") @db.Uuid
  bankAccountId   String    @map("bank_account_id") @db.Uuid
  fileName        String    @map("file_name")
  fileSize        Int       @map("file_size")
  format          String
  rowCount        Int       @map("row_count")
  processedCount  Int       @default(0) @map("processed_count")
  errorCount      Int       @default(0) @map("error_count")
  status          String    @default("pending")
  uploadedBy      String?   @map("uploaded_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id])

  @@map("import_batches")
}

model BankAccount {
  id                String    @id @default(uuid()) @db.Uuid
  communityId       String    @map("community_id") @db.Uuid
  accountName       String    @map("account_name")
  accountType       String    @map("account_type")
  bankName          String?   @map("bank_name")
  accountNumberMask String?   @map("account_number_mask")
  routingNumberMask String?   @map("routing_number_mask")
  openingBalance    Decimal?  @map("opening_balance") @db.Decimal(12, 2)
  currentBalance    Decimal?  @map("current_balance") @db.Decimal(12, 2)
  currency          String    @default("USD")
  notes             String?
  isActive          Boolean   @default(true) @map("is_active")
  plaidAccessToken  String?   @map("plaid_access_token")
  plaidAccountId    String?   @map("plaid_account_id")
  lastSyncedAt      DateTime? @map("last_synced_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])

  @@map("bank_accounts")
}

model Announcement {
  id              String    @id @default(uuid()) @db.Uuid
  communityId     String    @map("community_id") @db.Uuid
  title           String
  body            String
  type            String    @default("general")
  targetAudience  String    @default("all") @map("target_audience")
  publishedBy     String?   @map("published_by") @db.Uuid
  publishedAt     DateTime  @map("published_at")
  expiresAt       DateTime? @map("expires_at")
  isPinned        Boolean   @default(false) @map("is_pinned")
  readCount       Int       @default(0) @map("read_count")
  attachments     Json      @default("[]")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])

  @@index([publishedAt])
  @@index([isPinned])
  @@map("announcements")
}

model ComplianceItem {
  id              String    @id @default(uuid()) @db.Uuid
  communityId     String    @map("community_id") @db.Uuid
  type            String
  title           String
  description     String?
  dueDate         DateTime  @map("due_date")
  reminderDays    Int       @default(30) @map("reminder_days")
  status          String    @default("upcoming")
  completedAt     DateTime? @map("completed_at")
  completedBy     String?   @map("completed_by") @db.Uuid
  documentUrl     String?   @map("document_url")
  recurring       Boolean   @default(false)
  recurrenceRule  String?   @map("recurrence_rule")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])

  @@index([dueDate])
  @@index([status])
  @@map("compliance_items")
}

model MaintenanceRequest {
  id            String    @id @default(uuid()) @db.Uuid
  communityId   String    @map("community_id") @db.Uuid
  homeId        String?   @map("home_id") @db.Uuid
  reportedBy    String?   @map("reported_by") @db.Uuid
  title         String
  description   String?
  photos        Json      @default("[]")
  category      String?
  priority      String    @default("normal")
  status        String    @default("open")
  assignedTo    String?   @map("assigned_to") @db.Uuid
  vendorName    String?   @map("vendor_name")
  vendorPhone   String?   @map("vendor_phone")
  costEstimate  Decimal?  @map("cost_estimate") @db.Decimal(10, 2)
  actualCost    Decimal?  @map("actual_cost") @db.Decimal(10, 2)
  openedAt      DateTime  @default(now()) @map("opened_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])
  home      Home?     @relation(fields: [homeId], references: [id])

  @@index([status, priority])
  @@map("maintenance_requests")
}

model ChatSession {
  id               String    @id @default(uuid()) @db.Uuid
  communityId      String    @map("community_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  homeId           String?   @map("home_id") @db.Uuid
  sessionType      String    @default("general") @map("session_type")
  messages         Json
  summary          String?
  resolved         Boolean   @default(false)
  escalatedToBoard Boolean   @default(false) @map("escalated_to_board")
  escalationReason String?   @map("escalation_reason")
  feedbackRating   Int?      @map("feedback_rating")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id])

  @@index([userId])
  @@map("chat_sessions")
}

model ActivityLog {
  id          String    @id @default(uuid()) @db.Uuid
  communityId String    @map("community_id") @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  action      String
  entityType  String?   @map("entity_type")
  entityId    String?   @map("entity_id") @db.Uuid
  changes     Json?
  ipAddress   String?   @map("ip_address") @db.Inet
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  community Community @relation(fields: [communityId], references: [id])

  @@index([communityId, createdAt])
  @@index([action])
  @@map("activity_logs")
}

model PushSubscription {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  endpoint   String
  p256dh     String
  auth       String
  deviceInfo Json?    @map("device_info")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, isActive])
  @@map("push_subscriptions")
}